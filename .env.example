# LLM API Key
OPENAI_API_KEY="sk-..."
# Model for the Kriya agents (default openai/gpt-4o-mini)
SENTINEL_MODEL="openai/gpt-5.2"

# Supabase (business data + evidence storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"
# Supabase Storage bucket for uploaded evidence. Required in deployed mode.
KRIYA_EVIDENCE_BUCKET="kriya-evidence"

# Flue run state (sessions, workflow runs)
# Hosted Postgres connection string (Supabase → Settings → Database).
# Required in deployed mode; local dev falls back to SQLite when unset.
DATABASE_URL="postgresql://postgres:...@db.your-project.supabase.co:5432/postgres"
# Set NODE_ENV=production or KRIYA_DEPLOYED=true to enforce hosted state.
KRIYA_DEPLOYED="false"
ALLOW_LOCAL_FLUE_SQLITE="false"

# Provider adapters
KRIYA_PROVIDER_MODE="synthetic"
# Auth: every call sends `apikey: <secret key>`; tenant-gated routes
# (statements, transactions, cards, EMI, rewards, webhooks) additionally
# need `x-tenant-id`. Keys come from UAT dashboard → Access Keys, scoped
# per program. Verify with: node scripts/hyperface-smoke.mjs
HYPERFACE_BASE_URL="https://api-uat.hyperface.co"
HYPERFACE_TENANT_ID=""
HYPERFACE_ACCESS_KEY=""
HYPERFACE_SECRET_KEY=""
HYPERFACE_PROGRAM_ID=""
HYPERFACE_TEST_CUSTOMER_ID=""
HYPERFACE_TEST_ACCOUNT_ID=""
HYPERFACE_TEST_CARD_ID=""
# Live WRITES (lock/unlock/hotlist/replace/set-controls, refund, EMI create)
HYPERFACE_ALLOW_MUTATIONS="true"
# Authenticates INBOUND provider webhook deliveries: Hyperface ships no built-in signature, so we register this as a custom header at subscribe time and verify
HYPERFACE_WEBHOOK_SECRET=""

# Sarvam API Keys for multiple indian dialect voice input
VOICE_PROVIDER=""
SARVAM_API_KEY=""
SARVAM_STT_MODEL="saarika:v2.5"
SARVAM_TTS_MODEL="bulbul:v2"

# Telegram channel
# Create a bot with @BotFather, paste its token here, then register the
# webhook once (see DEPLOY.md). Customers reach Kriya by opening your
# t.me/<your_bot> link and tapping "Share my number" so we can match their
# card account. Leave empty to disable the Telegram channel.
TELEGRAM_BOT_TOKEN=""
# Optional shared secret. Pass the same value as `secret_token` when you call
# setWebhook; Telegram echoes it in the X-Telegram-Bot-Api-Secret-Token header
# and Kriya verifies it on every delivery (fail-closed when set).
TELEGRAM_WEBHOOK_SECRET=""

# OpenClaw channel (customer's own agent gateway)
# Bearer token OpenClaw agents present on POST /api/channels/openclaw/webhook.
# Replies return synchronously; set the callback for proactive push too.
OPENCLAW_API_KEY=""

# Misc
PORT="3583"
APP_BASE_URL="http://127.0.0.1:3583"
WEBHOOK_SIGNING_SECRET=""

DEMO_PHONE=""
