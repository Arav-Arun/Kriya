# Large Language Model API Configuration
OPENAI_API_KEY="sk-..."
# Model identifier for Kriya agents (e.g. openai/gpt-4o-mini)
SENTINEL_MODEL="openai/gpt-4o-mini"

# Supabase Storage and Client Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"
# Supabase Storage bucket for uploaded verification evidence documents
KRIYA_EVIDENCE_BUCKET="kriya-evidence"

# Flue Runtime Persistence Configuration
# Database URL for hosted Postgres instance (required in production environments)
DATABASE_URL="postgresql://postgres:...@db.your-project.supabase.co:5432/postgres"
# Deployment mode setting: set KRIYA_DEPLOYED=true in production/deployed UAT
KRIYA_DEPLOYED="false"
# Set to true only for local testing or non-production deployments
ALLOW_LOCAL_FLUE_SQLITE="false"

# Card Provider Integration (Hyperface UAT)
KRIYA_PROVIDER_MODE="synthetic"
HYPERFACE_BASE_URL="https://api-uat.hyperface.co"
HYPERFACE_TENANT_ID=""
HYPERFACE_ACCESS_KEY=""
HYPERFACE_SECRET_KEY=""
# Issuer-level master key — used for customer-details, rewards, and cashback APIs
HYPERFACE_ISSUER_SECRET_KEY=""
HYPERFACE_PROGRAM_ID=""
HYPERFACE_TEST_CUSTOMER_ID=""
HYPERFACE_TEST_ACCOUNT_ID=""
HYPERFACE_TEST_CARD_ID=""
# Enable write mutations (card lock/unlock, EMI creation, reward redemption)
HYPERFACE_ALLOW_MUTATIONS="true"
# Secret for verifying incoming Hyperface webhook notifications
HYPERFACE_WEBHOOK_SECRET=""

# Sarvam Voice Synthesis & Transcription Configuration
VOICE_PROVIDER=""
SARVAM_API_KEY=""
SARVAM_STT_MODEL="saarika:v2.5"
SARVAM_TTS_MODEL="bulbul:v2"

# Telegram Integration Configuration
# Bot token received from @BotFather
TELEGRAM_BOT_TOKEN=""
# Secret token for validating inbound Telegram webhook notifications
TELEGRAM_WEBHOOK_SECRET=""

# System Networking Configuration
PORT="3583"
APP_BASE_URL="http://127.0.0.1:3583"
WEBHOOK_SIGNING_SECRET=""

# Optional customer phone number shortcut for development sign-in
DEMO_PHONE=""
